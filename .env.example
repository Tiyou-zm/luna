TARO_APP_APP_ID=your-wechat-mini-program-appid
TARO_APP_CLOUDBASE_ENV_ID=your-cloudbase-env-id
TARO_APP_AUTH_EMAIL_DOMAIN=example.com
TARO_APP_COS_PUBLIC_BASE_URL=https://your-cos-domain.example.com
TARO_APP_API=

# Cloud function environment variables for createWechatPayment / wechatPaymentCallback.
# Fill these in Tencent CloudBase function configuration, not in the miniapp client bundle.
WECHAT_APPID=your-wechat-mini-program-appid
WECHAT_MCH_ID=your-wechat-pay-merchant-id
WECHAT_PAY_SERIAL_NO=your-wechat-pay-api-cert-serial-no
WECHAT_PAY_PRIVATE_KEY=your-wechat-pay-private-key-pem-or-base64
WECHAT_PAY_API_V3_KEY=your-wechat-pay-api-v3-key
WECHAT_PAY_NOTIFY_URL=https://your-domain.example.com/wechatPaymentCallback

# Cloud function environment variables for createVirtualPayment.
# Virtual payment is used for Luna membership; normal JSAPI payment should not sell membership.
WECHAT_APP_SECRET=your-wechat-mini-program-app-secret
VIRTUAL_PAY_OFFER_ID=your-wechat-virtual-payment-offer-id
VIRTUAL_PAY_APP_KEY=your-wechat-virtual-payment-production-app-key
VIRTUAL_PAY_SANDBOX_APP_KEY=your-wechat-virtual-payment-sandbox-app-key
VIRTUAL_PAY_ENV=0
VIRTUAL_PAY_MODE=short_series_goods
VIRTUAL_PAY_TRIAL_PRODUCT_ID=your-trial-membership-product-id
VIRTUAL_PAY_TRIAL_PRICE_CENTS=1990
VIRTUAL_PAY_TRIAL_PLAN_LEVEL=trial
